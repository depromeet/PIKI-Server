    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "GC pause (p99) · GC 빈도",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {

      "title": "JVM NonHeap (used)",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,

          "legendFormat": "pause p99"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(rate(jvm_gc_pause_seconds_count{application=\"PIKI\"}[$__rate_interval]))",
          "legendFormat": "gc/s"
        }
      ]
    },
    {
      "id": 103,
      "type": "row",
      "title": "호스트 (메모리 · swap · 디스크)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      }
    },
    {
      "id": 30,

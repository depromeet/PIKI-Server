        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum by (instance) (jvm_memory_max_bytes{application=\"PIKI\", area=\"heap\"})",
          "legendFormat": "max {{instance}}"
        }
      ]
    },
    {
      "id": 21,

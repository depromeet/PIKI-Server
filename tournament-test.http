### ============================================================
###  실행 방법: 각 섹션의 요청을 위에서 아래로 순서대로 실행
###  토큰·ID는 > {%%} 응답 핸들러가 자동으로 다음 요청에 전달됨
###
###  사전 조건
###  - 로컬 서버 구동: autossh 3307→RDS + redis + ./gradlew bootRun
###  - 위시 있는 유저 사용 권장 (0-1 결과에서 userId 선택)
###    예시 오너: 52895bdb-84a3-4abf-a62a-08a0edf8d32a (위시 아이템 다수 보유)
###    예시 멤버: eee97083-a9ef-4537-95bb-312407765247
###  - itemIds 는 해당 유저의 실제 위시 itemId 로 교체
### ============================================================

@host = http://localhost:8080


### ============================================================
###  STEP 0 — 토큰 발급 (users[0]=오너, users[1]=멤버)
### ============================================================

### 0-1. 유저 목록 조회 → 첫 번째·두 번째 userId 자동 저장
GET {{host}}/api/v1/dev/users?size=5
Accept: application/json

> {%
  var users = response.body.data;
  client.global.set("ownerUserId",  users[0].userId);
  client.global.set("memberUserId", users[1].userId);
%}

# 200 OK
# data: [
#   { "userId": "52895bdb-84a3-4abf-a62a-08a0edf8d32a", "nickname": "twdf9dcirx" },
#   { "userId": "eee97083-a9ef-4537-95bb-312407765247", "nickname": "재중이 바보" },
#   ...
# ]

###

### 0-2. 오너 토큰 발급 (Set-Cookie: access_token=<jwt> 에서 추출)
###   ※ accessToken 필드는 body 에 null — TokenCookieResponseAdvice 가 쿠키로 이동시킴
###   ※ Authorization: Bearer 헤더도 지원 (JwtAuthenticationFilter.extractFromHeader)
GET {{host}}/api/v1/dev/users/{{ownerUserId}}
Accept: application/json

> {%
  var cookie = response.headers.valueOf("Set-Cookie");
  var token = cookie ? cookie.split("access_token=")[1].split(";")[0] : "";
  client.global.set("ownerToken", token);
%}

# 200 OK
# data: { "userId": "...", "nickname": "...", "accessToken": null, "refreshToken": null }
# Set-Cookie: access_token=<jwt>; Path=/; HttpOnly

###

### 0-3. 멤버 토큰 발급
GET {{host}}/api/v1/dev/users/{{memberUserId}}
Accept: application/json

> {%
  var cookie = response.headers.valueOf("Set-Cookie");
  var token = cookie ? cookie.split("access_token=")[1].split(";")[0] : "";
  client.global.set("memberToken", token);
%}

# 200 OK  (0-2 와 동일 구조)


### ============================================================
###  STEP 1 — 솔로 플로우: 생성 → 아이템 → 시작 → 매치 → 삭제
### ============================================================

### 1-1. 토너먼트 생성
POST {{host}}/api/v1/tournaments
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{"name": "솔로 테스트 토너먼트"}

> {%
  client.global.set("tournamentId", response.body.data.tournamentId);
  client.global.set("inviteCode",   response.body.data.inviteCode);
%}

# 201 CREATED
# data: {
#   "tournamentId": 145,
#   "inviteCode": "GPH196",
#   "inviteExpiresAt": "2026-06-08T16:25:29.252804Z"
# }

###

### 1-2. 아이템 추가 — 위시 (위시에 READY 스냅샷 있는 아이템이어야 함)
###   ※ itemIds = 해당 유저 위시 목록의 itemId
POST {{host}}/api/v1/tournaments/{{tournamentId}}/items/wish
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{"itemIds": [329, 333]}

> {%
  var ids = response.body.data.tournamentItemIds;
  client.global.set("ti1", ids[0]);
  client.global.set("ti2", ids[1]);
%}

# 200 OK
# data: { "tournamentItemIds": [419, 420] }

###

### (대안) 1-2. 아이템 추가 — 링크 (백그라운드 Gemini 추출 → READY 까지 수초 대기)
POST {{host}}/api/v1/tournaments/{{tournamentId}}/items/link
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{"url": "https://www.musinsa.com/products/3068359"}

> {%
  client.global.set("ti1", response.body.data.tournamentItemId);
%}

# 200 OK
# data: { "tournamentItemId": <id> }

###

### 1-3. 토너먼트 단건 조회 (PENDING)
GET {{host}}/api/v1/tournaments/{{tournamentId}}
Authorization: Bearer {{ownerToken}}
Accept: application/json

# 200 OK
# data: {
#   "tournamentId": 145, "name": "솔로 테스트 토너먼트", "status": "PENDING", "isOwner": true,
#   "pending": {
#     "inviteCode": "GPH196",
#     "inviteExpiresAt": "2026-06-08T16:25:29.252804Z",
#     "items": [
#       { "tournamentItemId": 419, "name": "아디다스 삼바", "price": 89000, "currency": "KRW", "status": "READY" },
#       { "tournamentItemId": 420, "name": "반스 올드스쿨",  "price": 79000, "currency": "KRW", "status": "READY" }
#     ],
#     "participants": [{ "userId": "52895bdb-...", "nickname": "twdf9dcirx", ... }]
#   }
# }

###

### 1-4. 아이템 단건 조회
GET {{host}}/api/v1/tournaments/{{tournamentId}}/items/{{ti1}}
Authorization: Bearer {{ownerToken}}
Accept: application/json

# 200 OK
# data: {
#   "tournamentItemId": 419, "itemId": 329,
#   "sourceUrl": "https://www.musinsa.com/products/...",
#   "name": "아디다스 삼바", "imageUrl": "...", "price": 89000, "currency": "KRW", "status": "READY"
# }

###

### 1-5. 아이템 수정 (multipart — name·price·currency 중 변경할 필드만 전송)
PATCH {{host}}/api/v1/tournaments/{{tournamentId}}/items/{{ti1}}
Authorization: Bearer {{ownerToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="name"

수정된 상품명
--boundary
Content-Disposition: form-data; name="price"

59000
--boundary
Content-Disposition: form-data; name="currency"

KRW
--boundary--

# 200 OK  data: null

###

### 1-6. 아이템 삭제
DELETE {{host}}/api/v1/tournaments/{{tournamentId}}/items/{{ti1}}
Authorization: Bearer {{ownerToken}}
Accept: application/json

# 200 OK  data: null

###

### 1-7. 시작 (아이템 2개 이상·READY 상태 필요) → ti1·ti2 자동 저장
POST {{host}}/api/v1/tournaments/{{tournamentId}}/start
Authorization: Bearer {{ownerToken}}
Accept: application/json

> {%
  var items = response.body.data.items;
  client.global.set("ti1", items[0].tournamentItemId);
  client.global.set("ti2", items[1].tournamentItemId);
%}

# 200 OK
# data: {
#   "tournamentId": 145,
#   "items": [
#     { "tournamentItemId": 420, "name": "반스 올드스쿨",  "price": 79000, "currency": "KRW" },
#     { "tournamentItemId": 419, "name": "아디다스 삼바", "price": 89000, "currency": "KRW" }
#   ]
# }

###

### 1-8. 토너먼트 단건 조회 (IN_PROGRESS — 현재 라운드·남은 아이템)
GET {{host}}/api/v1/tournaments/{{tournamentId}}
Authorization: Bearer {{ownerToken}}
Accept: application/json

# 200 OK
# data: {
#   "status": "IN_PROGRESS",
#   "inProgress": {
#     "currentRound": 2,
#     "remainingItems": [
#       { "tournamentItemId": 420, "name": "반스 올드스쿨",  "status": "READY" },
#       { "tournamentItemId": 419, "name": "아디다스 삼바", "status": "READY" }
#     ]
#   }
# }

###

### 1-9. 매치 기록 (아이템 2개 = 결승 round 2, ti1 선택)
###   아이템 N개일 때 총 라운드 수 = N (결승 = 2)
POST {{host}}/api/v1/tournaments/{{tournamentId}}/matches
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "currentRound": 2,
  "firstTournamentItemId":    {{ti1}},
  "secondTournamentItemId":   {{ti2}},
  "selectedTournamentItemId": {{ti1}}
}

# 200 OK — 결승이면 완료 결과 즉시 반환, 중간 라운드면 data: null
# data: {
#   "result": [
#     { "rank": 1, "tournamentItemId": 419, "name": "아디다스 삼바", "price": 89000 },
#     { "rank": 2, "tournamentItemId": 420, "name": "반스 올드스쿨",  "price": 79000 }
#   ],
#   "hasGroupResult": false
# }

###

### 1-10. 토너먼트 단건 조회 (COMPLETED — 1~2위 결과, 아이템 4개면 1~4위)
GET {{host}}/api/v1/tournaments/{{tournamentId}}
Authorization: Bearer {{ownerToken}}
Accept: application/json

# 200 OK
# data: {
#   "status": "COMPLETED",
#   "completed": {
#     "result": [
#       { "rank": 1, "name": "아디다스 삼바", "price": 89000 },
#       { "rank": 2, "name": "반스 올드스쿨",  "price": 79000 }
#     ],
#     "hasGroupResult": false
#   }
# }

###

### 1-11. 토너먼트 목록 조회
GET {{host}}/api/v1/tournaments
Authorization: Bearer {{ownerToken}}
Accept: application/json

# 200 OK
# data: [
#   { "tournamentId": 145, "name": "솔로 테스트 토너먼트", "status": "COMPLETED",
#     "createdAt": "...", "participantProfileImages": ["..."] },
#   ...
# ]

###

### 1-12. 토너먼트 삭제
###   PENDING  → 소프트딜리트 (토너먼트·아이템·전체 TU cascade)
###   COMPLETED → 오너 TU 만 제거 + 플레이링크 즉시 만료 (멤버 CLONE 유지)
DELETE {{host}}/api/v1/tournaments/{{tournamentId}}
Authorization: Bearer {{ownerToken}}
Accept: application/json

# 200 OK  data: null


### ============================================================
###  STEP 2 — 소셜 플로우: 초대 → 아이템 담기 → ROOT/CLONE 플레이 → 그룹결과 → 플레이링크
### ============================================================

### 2-1. 소셜 토너먼트 생성 (inviteDurationMinutes 기본 30, 최대 1440)
POST {{host}}/api/v1/tournaments
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{"name": "소셜 테스트 토너먼트", "inviteDurationMinutes": 60}

> {%
  client.global.set("tournamentId", response.body.data.tournamentId);
  client.global.set("inviteCode",   response.body.data.inviteCode);
%}

# 201 CREATED
# data: { "tournamentId": 146, "inviteCode": "AUL897", "inviteExpiresAt": "2026-06-08T16:58:18.712408Z" }

###

### 2-2. 초대 마감 시간 연장 (PENDING 상태에서만 가능)
PATCH {{host}}/api/v1/tournaments/{{tournamentId}}/invite
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{"inviteDurationMinutes": 120}

# 200 OK  data: "2026-06-08T17:58:18.712408Z"  (새 만료 시각)
# 409 CONFLICT — PENDING 이 아닌 상태에서 호출 시

###

### 2-3. 초대 미리보기 조회 (링크 입장 — 인증 불필요)
GET {{host}}/api/v1/tournaments/{{tournamentId}}/invite-preview
Accept: application/json

# 200 OK
# data: { "tournamentId": 146, "tournamentName": "소셜 테스트 토너먼트", "itemCount": 0, "participantCount": 1 }

###

### 2-4. 초대 코드로 미리보기 조회 (코드 입장)
GET {{host}}/api/v1/tournaments/by-invite-code?code={{inviteCode}}
Accept: application/json

# 200 OK  (2-3 과 동일 구조)

###

### 2-5. 회원 입장 (링크로 — inviteCode null)
POST {{host}}/api/v1/tournaments/{{tournamentId}}/join
Authorization: Bearer {{memberToken}}
Content-Type: application/json

{"inviteCode": null}

# 200 OK  data: null

###

### 2-5B. 회원 입장 (초대 코드로)
POST {{host}}/api/v1/tournaments/{{tournamentId}}/join
Authorization: Bearer {{memberToken}}
Content-Type: application/json

{"inviteCode": "{{inviteCode}}"}

# 200 OK  data: null

###

### 2-6. 비회원 게스트 입장 → guestToken 자동 저장
###   ※ accessToken 은 body null, Set-Cookie 에서 추출
POST {{host}}/api/v1/tournaments/{{tournamentId}}/join/guest
Content-Type: application/json

{"inviteCode": null, "nickname": "행복한토끼"}

> {%
  var cookie = response.headers.valueOf("Set-Cookie");
  var token = cookie ? cookie.split("access_token=")[1].split(";")[0] : "";
  client.global.set("guestToken", token);
%}

# 201 CREATED
# data: {
#   "userId": "e1d0bc8e-e0c5-42f3-b0d7-4287dc32222d",
#   "nickname": "행복한토끼",
#   "profileImage": "...",
#   "tournamentId": 146,
#   "accessToken": null, "refreshToken": null
# }
# Set-Cookie: access_token=<jwt>; Path=/; HttpOnly

###

### 2-7. 아이템 담기 — 오너 (위시, itemIds 실제 값으로 교체)
POST {{host}}/api/v1/tournaments/{{tournamentId}}/items/wish
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{"itemIds": [329, 333]}

> {%
  var ids = response.body.data.tournamentItemIds;
  client.global.set("ti1", ids[0]);
  client.global.set("ti2", ids[1]);
%}

# 200 OK
# data: { "tournamentItemIds": [419, 420] }

###

### 2-8. 아이템 담기 — 멤버 (링크, 백그라운드 추출)
POST {{host}}/api/v1/tournaments/{{tournamentId}}/items/link
Authorization: Bearer {{memberToken}}
Content-Type: application/json

{"url": "https://www.musinsa.com/products/3068359"}

# 200 OK  data: { "tournamentItemId": <id> }

###

### 2-9. 오너 시작 → ROOT 플레이 시작, ti1·ti2 자동 저장
###   오너(ROOT)와 멤버(CLONE)는 각각 독립 인스턴스로 플레이
POST {{host}}/api/v1/tournaments/{{tournamentId}}/start
Authorization: Bearer {{ownerToken}}
Accept: application/json

> {%
  var items = response.body.data.items;
  client.global.set("ti1", items[0].tournamentItemId);
  client.global.set("ti2", items[1].tournamentItemId);
%}

# 200 OK
# data: {
#   "tournamentId": 146,   ← ROOT ID (오너의 인스턴스)
#   "items": [
#     { "tournamentItemId": 420, "name": "반스 올드스쿨",  "price": 79000 },
#     { "tournamentItemId": 419, "name": "아디다스 삼바", "price": 89000 }
#   ]
# }

###

### 2-10. 오너 매치 기록 (ROOT)
POST {{host}}/api/v1/tournaments/{{tournamentId}}/matches
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "currentRound": 2,
  "firstTournamentItemId":    {{ti1}},
  "secondTournamentItemId":   {{ti2}},
  "selectedTournamentItemId": {{ti1}}
}

# 200 OK
# data: {
#   "result": [
#     { "rank": 1, "tournamentItemId": 419, "name": "아디다스 삼바", "price": 89000 },
#     { "rank": 2, "tournamentItemId": 420, "name": "반스 올드스쿨",  "price": 79000 }
#   ],
#   "hasGroupResult": false   ← 멤버가 아직 미완료
# }

###

### 2-11. 멤버 start → CLONE 자동 생성, cloneTournamentId 저장
###   data.tournamentId = 멤버 전용 CLONE ID (ROOT ID 146 과 다름)
###   data.items = ROOT 아이템과 동일 (sourceTournamentId 로 참조, DB 행 없음)
POST {{host}}/api/v1/tournaments/{{tournamentId}}/start
Authorization: Bearer {{memberToken}}
Accept: application/json

> {%
  client.global.set("cloneTournamentId", response.body.data.tournamentId);
%}

# 200 OK
# data: {
#   "tournamentId": 147,   ← CLONE ID (멤버의 인스턴스)
#   "items": [             ← ROOT 와 동일한 tournamentItemId 공유
#     { "tournamentItemId": 420, "name": "반스 올드스쿨" },
#     { "tournamentItemId": 419, "name": "아디다스 삼바" }
#   ]
# }

###

### 2-12. 멤버 매치 기록 (CLONE — tournamentItemId 는 ROOT 것과 동일)
###   ※ cloneTournamentId(147) 로 요청해야 함 — ROOT ID(146) 사용 시 403
POST {{host}}/api/v1/tournaments/{{cloneTournamentId}}/matches
Authorization: Bearer {{memberToken}}
Content-Type: application/json

{
  "currentRound": 2,
  "firstTournamentItemId":    {{ti1}},
  "secondTournamentItemId":   {{ti2}},
  "selectedTournamentItemId": {{ti2}}
}

# 200 OK
# data: {
#   "result": [
#     { "rank": 1, "tournamentItemId": 420, "name": "반스 올드스쿨" },
#     { "rank": 2, "tournamentItemId": 419, "name": "아디다스 삼바" }
#   ],
#   "hasGroupResult": true   ← 이제 그룹 결과 조회 가능
# }

###

### 2-13. 그룹 결과 조회 (오너·멤버 모두 완료 시 200)
###   ROOT tournamentId(146) 로 요청
GET {{host}}/api/v1/tournaments/{{tournamentId}}/group-result
Authorization: Bearer {{ownerToken}}
Accept: application/json

# 200 OK
# data: {
#   "items": [
#     { "rank": 1, "itemId": 329, "name": "아디다스 삼바", "price": 89000,
#       "chosenBy": [{ "userId": "52895bdb-...", "nickname": "twdf9dcirx" }] },
#     { "rank": 2, "itemId": 333, "name": "반스 올드스쿨",  "price": 79000,
#       "chosenBy": [{ "userId": "eee97083-...", "nickname": "재중이 바보" }] }
#   ]
# }
# 동점이면 순서는 서버가 임의로 결정

###

### 2-14. 플레이링크 생성 (오너만 가능, 14일 고정)
POST {{host}}/api/v1/tournaments/{{tournamentId}}/play-link
Authorization: Bearer {{ownerToken}}
Accept: application/json

# 200 OK  data: "2026-06-22T15:59:32.242083Z"  (만료 시각)

###

### 2-15. 플레이링크 정보 조회 (인증 불필요)
GET {{host}}/api/v1/tournaments/{{tournamentId}}/play-link-info
Accept: application/json

# 200 OK
# data: {
#   "sourceTournamentId": 146,
#   "tournamentName": "소셜 테스트 토너먼트",
#   "itemCount": 2,
#   "playLinkExpiresAt": "2026-06-22T15:59:32.242083Z"
# }

###

### 2-16. 플레이링크로 복제 — 인증된 유저가 자신만의 CLONE 생성
###   ※ guestToken 은 0-2 와 동일하게 Set-Cookie 에서 추출
POST {{host}}/api/v1/tournaments/{{tournamentId}}/from-play-link
Authorization: Bearer {{guestToken}}
Accept: application/json

> {%
  client.global.set("playLinkCloneId", response.body.data);
%}

# 201 CREATED  data: 148  (새 CLONE tournamentId)

###

### 2-17. 복제된 CLONE 단건 조회 (PENDING 상태, 아이템 없음 — start 시 ROOT 참조)
GET {{host}}/api/v1/tournaments/{{playLinkCloneId}}
Authorization: Bearer {{guestToken}}
Accept: application/json

# 200 OK
# data: {
#   "tournamentId": 148, "name": "소셜 테스트 토너먼트", "status": "PENDING", "isOwner": true,
#   "pending": {
#     "inviteCode": "XXJ493",
#     "items": [],   ← CLONE 은 DB 아이템 없음, start 시 ROOT(146) 에서 해소
#     "participants": [{ "userId": "e1d0bc8e-...", "nickname": "행복한토끼" }]
#   }
# }
